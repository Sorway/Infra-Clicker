PORT=3000
SITE_URL=https://clicker.consto.com
SESSION_SECRET=remplacez-par-une-cle-aleatoire-longue-et-secrete

# MariaDB
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=infra_clicker
DB_PASSWORD=mot-de-passe-fort
DB_NAME=infra_clicker
DB_CONNECTION_LIMIT=10

# Active la lecture de CF-Connecting-IP et CF-IPCountry.
# L’origine ne doit être accessible qu’à travers Cloudflare / votre reverse proxy.
CLOUDFLARE_PROXY=true
NETWORK_DEBUG=false

# Cache serveur : réduit les lectures/écritures MariaDB
CACHE_FLUSH_MS=10000
CACHE_TTL_MS=1800000
LEADERBOARD_CACHE_MS=15000

# Informations à afficher dans la politique de confidentialité
PRIVACY_CONTACT=contact@example.com
HOST_NAME=Nom et coordonnées de l’hébergeur
