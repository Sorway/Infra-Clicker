<!DOCTYPE html>
<html lang="fr" data-theme="ocean">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="theme-color" content="#071018">
  <meta name="color-scheme" content="dark">
  <meta name="application-name" content="Infra Clicker">
  <meta name="apple-mobile-web-app-title" content="Infra Clicker">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="description" content="<%= description %>">
  <meta name="keywords" content="clicker, jeu incrémental, sysadmin, DevOps, réseau, Linux, Kubernetes, serveur, infrastructure">
  <meta name="author" content="Jonathan GP">
  <meta name="creator" content="Jonathan GP">
  <meta name="publisher" content="Jonathan GP">
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1">
  <meta name="referrer" content="strict-origin-when-cross-origin">
  <meta name="format-detection" content="telephone=no">
  <title><%= title %></title>
  <link rel="canonical" href="<%= canonicalUrl %>">

  <meta property="og:type" content="website">
  <meta property="og:locale" content="fr_FR">
  <meta property="og:site_name" content="Infra Clicker">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="<%= description %>">
  <meta property="og:url" content="<%= canonicalUrl %>">
  <meta property="og:image" content="<%= socialImageUrl %>">
  <meta property="og:image:secure_url" content="<%= socialImageUrl %>">
  <meta property="og:image:type" content="image/png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="Infra Clicker, jeu incrémental SysAdmin, Réseau et DevOps">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title %>">
  <meta name="twitter:description" content="<%= description %>">
  <meta name="twitter:image" content="<%= socialImageUrl %>">
  <meta name="twitter:image:alt" content="Infra Clicker, jeu incrémental SysAdmin, Réseau et DevOps">

  <link rel="icon" type="image/png" sizes="192x192" href="/img/favicon.png">
  <link rel="apple-touch-icon" href="/img/favicon.png">
  <script type="application/ld+json">
    <%- JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'VideoGame',
      name: 'Infra Clicker',
      url: canonicalUrl,
      image: socialImageUrl,
      description,
      author: {
        '@type': 'Person',
        name: 'Jonathan GP'
      },
      applicationCategory: 'Game',
      operatingSystem: 'Web browser',
      genre: ['Incremental game', 'Simulation', 'Strategy'],
      inLanguage: 'fr-FR',
      isAccessibleForFree: true
    }) %>
  </script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="<%= typeof pageClass !== 'undefined' ? pageClass : '' %>">
  <div class="ambient-grid" aria-hidden="true"></div>
  <%- body %>
  <div id="toast-container" class="toast-container" aria-live="polite"></div>
  <aside id="privacy-notice" class="privacy-notice hidden" aria-label="Information sur la sauvegarde">
    <div>
      <strong>Vos données restent sur cet appareil</strong>
      <p>Infra Clicker utilise un cookie de session nécessaire à la sauvegarde sécurisée et du stockage local pour vos préférences. Aucun cookie publicitaire ni outil d’analyse n’est utilisé.</p>
    </div>
    <div class="privacy-notice-actions">
      <a href="/privacy">En savoir plus</a>
      <button id="privacy-notice-accept">Compris</button>
    </div>
  </aside>
  <% if (typeof pageScript !== 'undefined' && pageScript) { %>
    <script type="module" src="<%= pageScript %>"></script>
  <% } %>
  <script src="/js/privacy-notice.js" defer></script>
</body>
</html>
